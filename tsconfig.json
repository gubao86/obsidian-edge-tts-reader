{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": ".",
    "rootDir": ".",
    "moduleResolution": "node",
    "noEmit": true
  },
  "include": ["main.ts", "settings.ts"],
  "exclude": ["node_modules"]
}
